{
  "name": "weltmeister",
  "version": "0.1.0",
  "private": true,
  "description": "World Cup 2026 prediction engine, tournament simulator, and manage-mode web app",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @weltmeister/sim build && pnpm --filter @weltmeister/web build",
    "test": "pnpm --filter @weltmeister/sim test",
    "dev": "pnpm --filter @weltmeister/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.1"
}
